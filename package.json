{
  "name": "writestorm",
  "version": "0.1.0",
  "description": "Local-first desktop writing analysis workbench.",
  "private": true,
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build": "electron-forge package",
    "check": "npm run typecheck && npm run test:unit && npm run test:integration && npm run test:e2e",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:secondary-display": "npm run build && playwright test --grep @secondary-display"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^43.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@openai/codex-sdk": "0.144.6",
    "@tanstack/react-query": "^5.101.2",
    "better-sqlite3": "^12.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  }
}
